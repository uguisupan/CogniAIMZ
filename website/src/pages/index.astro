---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 各種コンテンツコレクションを取得
const devlogs = await getCollection('devlog');
const races = await getCollection('race');
const books = await getCollection('books');

// 公開日の新しい順にソート
const sortedDevlogs = devlogs.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedRaces = races.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sortedBooks = books.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 日付フォーマット (YYYY.MM.DD)
const formatDate = (date: Date) => {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}.${m}.${d}`;
};
---

<Layout title="サークル公式サイト">
    <!-- ヒーローセクション（技術書カバー＆お堅いタイトル） -->
    <section class="hero-section" id="hero">
        <div class="hero-info">
            <div class="hero-tag font-mono">DOUJINSHI PROJ: #001</div>
            <h2 class="hero-title-en font-mono">Real-time Measurement & Training Tools</h2>
            <h1 class="hero-title-jp">
                アマチュアレーサーにおける<br>
                運転操作向上のための<br>
                トレーニングツール①　初等・ブレーキ編
            </h1>
            <p class="hero-desc">
                ロードセル式ペダルによる踏力コントロールをミリ秒単位でデータ化。
                脳と足裏の「知覚ギャップ」を埋め、常に狙った通りのトレイルブレーキングを再現するための理論とツールの解説書。
            </p>
            <div style="margin-top: 10px;">
                <a href="#products" class="product-action-btn font-mono" style="text-decoration: none; display: inline-block;">SYSTEM OVERVIEW ➔</a>
            </div>
        </div>
        
        <div class="hero-book-preview">
            <!-- 00年代萌え系解説書風 表紙 -->
            <div class="book-cover" style="padding: 0; overflow: hidden; display: block;">
                <img src={`${import.meta.env.BASE_URL}/book_cover.jpg`} alt="技術書表紙" style="width: 100%; height: 100%; object-fit: cover; display: block;">
            </div>
        </div>
    </section>

    <!-- メイドさん解説セクション (About) -->
    <section class="about-section" id="about">
        <div class="maid-avatar-area">
            <div class="maid-stand-placeholder" style="border: none; background: none; height: auto;">
                <img src={`${import.meta.env.BASE_URL}/maid_mai.jpg`} alt="マイ" style="width: 100%; max-height: 320px; border-radius: 0; box-shadow: 0 5px 15px rgba(0,0,0,0.15); object-fit: cover; display: block;">
            </div>
            <div class="maid-name font-mono">小国マイ - Mai Koguni</div>
        </div>
        
        <div class="about-dialog-box">
            <div class="dialog-header font-mono">COGNITIVE_SYSTEM_EXPLANATION.txt</div>
            <div class="dialog-text">
                <p>
                    「ようこそ、<strong>CogniAIMZ（コグニエイムズ）</strong>へ！私は解説のマイだよ！」
                </p>
                <p>
                    「モータースポーツにおいて、ブレーキングは単に車を減速させるだけじゃなくて、荷重移動をコントロールして車の向きを変える最も重要なフェーズなんだ。でも、多くの初中級ドライバーは、自分がペダルをどれだけリリースしているか、脳内のイメージと実際の足裏の圧力（踏力）に大きな<span class="pink-highlight">『認知のズレ（Cognitive Gap）』</span>を抱えちゃっているんだよね。」
                </p>
                <p>
                    「私たちのサークルでは、ミリ秒単位でロードセルペダルの挙動をキャプチャして、人間の感覚のフィードバックループを強化するツールと理論を研究しているよ。名前はシステム開発研究所のように堅苦しいけど、中身はレースゲームとメカが大好きなオタク魂でいっぱい！一緒に『狙った通りの1ミリ秒』を追求してみない？」
                </p>
            </div>
        </div>
    </section>

    <!-- キリ番アクセスカウンター -->
    <div class="counter-panel">
        <span class="counter-title">ACCESS COUNTER</span>
        <div class="counter-numbers">
            <span class="counter-num">9</span>
            <span class="counter-num">9</span>
            <span class="counter-num">9</span>
            <span class="counter-num">9</span>
            <span class="counter-num">9</span>
            <span class="counter-num">9</span>
            <span class="counter-num font-mono neon-num">9</span>
            <span class="counter-num font-mono neon-num">9</span>
        </div>
        <span class="counter-note">※カウンター限界突破につき機能停止中（ウソ）</span>
    </div>

    <!-- 書籍＆ツール紹介 (Products) -->
    <section class="products-section" id="products">
        <h2 class="section-title-cyber">Project Products</h2>
        <div class="products-grid">
            <!-- K2MF-001: Brake Trainer -->
            <a href="https://uguisupan.github.io/CogniAIMZ/brake-trainer-K2MF-001/index.html" target="_blank" rel="noopener noreferrer" class="product-card active" id="product-k2mf-001">
                <div class="product-content">
                    <div class="product-meta">SYSTEM MODEL: K2MF-001 | v0.1.0alpha 2026/05/29</div>
                    <h3 class="product-title">Brake Trainer</h3>
                    <p class="product-desc font-sans">
                        ロードセルペダルのリリース挙動にフォーカスし、ターゲットの踏力（%）へミリ秒単位でリリースコントロール（戻し）を行うリズムゲーム型トレーニングツール。GitHub Pagesで稼働中。
                    </p>
                    <p class="product-desc font-sans" style="font-size: 0.8rem; color: var(--color-pink); font-weight: bold;">
                        ※プレイにはGamepad APIに対応したUSBロードセルペダル、または互換コントローラーが必要です。
                    </p>
                </div>
                <div class="product-footer">
                    <span class="product-status font-mono">STATUS: ONLINE ➔</span>
                    <span class="product-action-btn font-mono">LAUNCH APP</span>
                </div>
            </a>

            <!-- K2MF-002: Throttle & Clutch (Locked) -->
            <div class="product-card locked" id="product-k2mf-002">
                <div class="product-content">
                    <div class="product-meta">SYSTEM MODEL: K2MF-002</div>
                    <h3 class="product-title">Throttle & Clutch</h3>
                    <p class="product-desc">
                        ハーフスロットル維持、ヒール・アンド・トウ時の同調、クラッチのミートポイント再現性を高めるための総合ペダルワークトレーニングモジュール。
                    </p>
                </div>
                <div class="product-footer">
                    <span class="product-status font-mono">STATUS: DEVELOPMENT</span>
                </div>
            </div>

            <!-- K2MF-003: H-Shifter (Locked) -->
            <div class="product-card locked" id="product-k2mf-003">
                <div class="product-content">
                    <div class="product-meta">SYSTEM MODEL: K2MF-003</div>
                    <h3 class="product-title">H-Shifter Trainer</h3>
                    <p class="product-desc">
                        ドグミッションの噛み合わせタイミングやシンクロ機構のメカニズムを体感し、シフトミスを極限まで減らすためのギアゲート練習デバイスシミュレーター。
                    </p>
                </div>
                <div class="product-footer">
                    <span class="product-status font-mono">STATUS: CONCEPT</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 開発ブログ ＆ イベントスケジュール -->
    <div class="info-columns">
        <!-- ブログエリア (Devlog & Race) -->
        <section class="devlog-section" id="devlog">
            <h2 class="section-title-cyber">Research & Devlog</h2>
            <div class="blog-list" style="margin-bottom: 30px;">
                {sortedDevlogs.slice(0, 5).map((post) => (
                    <a href={`${import.meta.env.BASE_URL}/devlog/${post.id}/`} class="blog-item">
                        <div class="blog-meta">
                            <span class="blog-date font-mono">{formatDate(post.data.pubDate)}</span>
                            <span class="blog-tag font-mono">#{post.data.tag}</span>
                        </div>
                        <h3 class="blog-title">{post.data.title}</h3>
                    </a>
                ))}
            </div>

            <h2 class="section-title-cyber" id="race" style="margin-top: 40px;">Motorsports Race Logs</h2>
            <div class="blog-list">
                {sortedRaces.slice(0, 5).map((post) => (
                    <a href={`${import.meta.env.BASE_URL}/race/${post.id}/`} class="blog-item">
                        <div class="blog-meta">
                            <span class="blog-date font-mono">{formatDate(post.data.pubDate)}</span>
                            <span class="blog-tag font-mono" style="color: var(--color-cyan);">#Race</span>
                        </div>
                        <h3 class="blog-title">{post.data.title}</h3>
                    </a>
                ))}
            </div>
        </section>

        <!-- 出展情報 (Event & Books) -->
        <section class="event-section" id="event">
            <h2 class="section-title-cyber">Next Mission</h2>
            <div class="event-box" style="margin-bottom: 30px;">
                <div class="event-details">
                    <div class="event-header">
                        <h3 class="event-name">（近い将来の）技術書典 XX</h3>
                        <span class="event-date font-mono">2026.XX.XX</span>
                    </div>
                    <div class="event-info-row">
                        <span class="event-label font-sans">サークル名:</span>
                        <span class="event-value">CogniAIMZ (コグニエイムズ)</span>
                    </div>
                    <div class="event-info-row">
                        <span class="event-label font-sans">配置スペース:</span>
                        <span class="event-value highlight font-mono">ζ-FFb</span>
                    </div>
                    <div class="event-info-row">
                        <span class="event-label font-sans">頒布書籍:</span>
                        <span class="event-value">アマチュアレーサーにおける…</span>
                    </div>
                    <div class="event-info-row" style="margin-top: 15px;">
                        <span class="event-label font-sans" style="font-size: 0.8rem; line-height: 1.5; color: var(--text-muted);">
                            ※詳細なブース位置や委託・通販(BOOTH)リンクは決定次第、本エリアおよび公式SNSにて順次お知らせいたします。
                        </span>
                    </div>
                </div>
            </div>

            <h2 class="section-title-cyber">Published Books</h2>
            <div class="blog-list">
                {sortedBooks.map((post) => (
                    <a href={`${import.meta.env.BASE_URL}/books/${post.id}/`} class="blog-item">
                        <div class="blog-meta">
                            <span class="blog-date font-mono">{formatDate(post.data.pubDate)}</span>
                            <span class="blog-tag font-mono" style="color: var(--color-pink);">#Book</span>
                        </div>
                        <h3 class="blog-title">{post.data.title}</h3>
                    </a>
                ))}
            </div>
        </section>
    </div>
</Layout>
